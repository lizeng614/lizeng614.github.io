<header class="site-header">
  <div class="site-header-top">
    <div class="site-brand">
      <a class="site-title" href="<%= url_for('/') %>"><%= config.title %></a>
      <div class="social-links">
        <% if (config.social && config.social.x && config.social.x.url) { %>
          <a href="<%= config.social.x.url %>" target="_blank" rel="noopener noreferrer"><%= config.social.x.label || 'X' %></a>
        <% } %>
        <a href="<%= url_for('/atom.xml') %>">RSS</a>
      </div>
    </div>

    <div class="site-header-controls">
      <nav class="site-nav" aria-label="Primary">
        <a href="<%= url_for('/') %>" data-i18n="nav.home">Home</a>
        <a href="<%= url_for('/blog/') %>" data-i18n="nav.posts">Posts</a>
        <a href="<%= url_for('/archives/') %>" data-i18n="nav.archive">Archive</a>
        <a href="<%= url_for('/search/') %>" data-i18n="nav.search">Search</a>
      </nav>

      <div class="language-switch" aria-label="Language">
        <button type="button" class="language-switch-button" data-language-switch="en" aria-label="Switch to English">EN</button>
        <span class="language-switch-separator">/</span>
        <button type="button" class="language-switch-button" data-language-switch="zh" aria-label="切换到中文">中文</button>
      </div>
    </div>
  </div>
</header>
